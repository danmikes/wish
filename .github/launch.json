{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Flask Debug",
      "type": "python",
      "request": "launch",
      "module": "flask",
      "env": {
        "FLASK_APP": "app/__init__.py",
        "FLASK_DEBUG": "1",
        "FLASK_ENV": "development"
      },
      "args": [
        "run",
        "--no-debugger",
        "--no-reload",
        "--host=0.0.0.0",
        "--port=5000"
      ],
      "jinja": true,
      "justMyCode": false
    },
    {
      "name": "Flask Run File",
      "type": "python",
      "request": "launch",
      "program": "${workspaceFolder}/app/__init__.py",
      "console": "integratedTerminal",
      "env": {
        "FLASK_APP": "app/__init__.py",
        "FLASK_DEBUG": "1"
      },
      "args": [],
      "jinja": true,
      "justMyCode": false
    }
  ]
}
